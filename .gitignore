# Raw data and generated outputs (not tracked, see CLAUDE.md)
data/*
!data/.gitkeep
# Provenance manifest is committed on purpose (see src/manifest.py). Must be its own comment
# line, not trailing the pattern below — gitignore has no inline-comment syntax, so
# "!data/manifest.json   # ..." was previously matched literally and never actually un-ignored
# the file (confirmed via `git log --all -- data/manifest.json`: zero commits, ever).
!data/manifest.json
outputs/*
!outputs/.gitkeep

# Jupyter
.ipynb_checkpoints/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# VS Code (keep settings.json, ignore the rest)
.vscode/*
!.vscode/settings.json

# OS
.DS_Store
Thumbs.db
