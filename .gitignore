# Raw data and generated outputs (not tracked, see CLAUDE.md)
data/*
!data/.gitkeep
!data/manifest.json   # provenance manifest is committed on purpose (see src/manifest.py)
outputs/*
!outputs/.gitkeep

# Jupyter
.ipynb_checkpoints/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# VS Code (keep settings.json, ignore the rest)
.vscode/*
!.vscode/settings.json

# OS
.DS_Store
Thumbs.db
